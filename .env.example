# 3PL Supply Chain Visibility Platform — environment variables
# Copy to .env at the repository root and adjust values for your environment.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

# SQLAlchemy/asyncpg connection string used by the FastAPI backend.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/visibility

# Docker Compose PostgreSQL credentials (used when the database service is added).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=visibility

# -----------------------------------------------------------------------------
# API (FastAPI backend)
# -----------------------------------------------------------------------------

# Host and port the API binds to when started with uvicorn.
API_HOST=0.0.0.0
API_PORT=8000

# Allowed browser origins for CORS (comma-separated). Include the Vite dev server by default.
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend (Vite React SPA)
# -----------------------------------------------------------------------------

# Base URL for API requests from the browser. Use the backend origin in local dev.
VITE_API_BASE_URL=http://localhost:8000
